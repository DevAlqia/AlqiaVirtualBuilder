# ─── Alqia Virtual Builder — Variables de Entorno ────────────────────────────
#
# Copia este archivo a .env y rellena con tus credenciales reales de Supabase.
# NUNCA subas .env a git. Solo sube este .env.example.
#
# Obtén estas variables en: https://app.supabase.com → Tu proyecto → Settings → API
#   - VITE_SUPABASE_URL     → Project URL
#   - VITE_SUPABASE_ANON_KEY → anon / public key  (segura para frontend, RLS protege los datos)
#
# IMPORTANTE:
#   - NO uses service_role key en el frontend. Nunca.
#   - El anon key es público por diseño — Supabase usa RLS para proteger los datos.
#   - Activa RLS en todas las tablas antes de ir a producción real.

VITE_SUPABASE_URL=https://dfnwwmamcrssmhnjrmxa.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRmbnd3bWFtY3Jzc21obmpybXhhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA3NjQyODksImV4cCI6MjA5NjM0MDI4OX0.iLezzEtuVkPopQmX4FkWx5lw_rJR_FPgG4b311bGnQs

# ─── Feature flags ────────────────────────────────────────────────────────────
# Cambia a 'false' para activar Supabase. Mientras sea 'true' usa datos mock como fallback.
VITE_USE_MOCK_DATA=true

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Alqia Virtual Builder
VITE_APP_VERSION=0.1.0
